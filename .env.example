# ===================== PostgreSQL =====================
POSTGRES_DB=educonnect
POSTGRES_USER=educonnect_user
POSTGRES_PASSWORD=your_strong_password_here

# ===================== Redis =====================
REDIS_PASSWORD=your_redis_password_here

# ===================== RabbitMQ =====================
RABBITMQ_USER=educonnect_admin
RABBITMQ_PASSWORD=your_rabbitmq_password_here

# ===================== JWT =====================
JWT_SECRET=generate_a_random_64_char_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===================== Gemini AI =====================
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ===================== PgAdmin =====================
PGADMIN_EMAIL=admin@educonnect.local
PGADMIN_PASSWORD=your_pgadmin_password_here

# ===================== Service URLs (internal docker) =====================
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
FILE_SERVICE_URL=http://file-service:8003
AI_SERVICE_URL=http://ai-service:8004
LOG_SERVICE_URL=http://log-service:8005
NOTIFICATION_SERVICE_URL=http://notification-service:8006

# ===================== Frontend (public) =====================
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_USER_SERVICE_URL=http://localhost:8002
NEXT_PUBLIC_FILE_SERVICE_URL=http://localhost:8003
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8004
NEXT_PUBLIC_NOTIFICATION_WS_URL=ws://localhost:8006/ws
