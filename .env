# ===================== Redis =====================
REDIS_PASSWORD=Redis@EduConnect2024

# ===================== RabbitMQ =====================
RABBITMQ_USER=educonnect_admin
RABBITMQ_PASSWORD=RabbitMQEduConnect2024

# ===================== JWT =====================
JWT_SECRET=8f4b2c9d1a7e6f3b0d5c2e8a4f1b7d3c9e2a6f8b4d1c7e3a9f2b6d8c4e1a7f3b
